{
  "name": "telegram-mushroom-archiver",
  "version": "1.0.0",
  "description": "Fetch Telegram channel messages, OCR screenshots, repost extracted text, archive markdown, and export mushroom lore PDFs.",
  "type": "module",
  "scripts": {
    "fetch": "node src/index.js",
    "regenerate": "node src/regenerate-from-telegram.js",
    "update-text-message": "node src/update-text-message.js",
    "set-message-hashtags": "node src/set-message-hashtags.js",
    "set-ocr-hashtags": "node src/set-ocr-hashtags.js",
    "clear-message-hashtags": "node src/clear-message-hashtags.js",
    "backfill-posted-message-ids": "node src/backfill-posted-message-ids.js",
    "rebuild-ocr-reposts": "node src/rebuild-ocr-reposts.js",
    "clean-text-duplicates": "node src/clean-text-duplicates.js",
    "analyze:lore-prompt": "node src/analyze-lore-prompt.js",
    "analyze:pdf-structure": "node src/analyze-pdf-structure.js",
    "audit:untagged": "node src/audit-untagged-routing.js",
    "game:start": "node app/scripts/start-game-dev.js",
    "game:start:backend": "node app/server/start.js",
    "game:build": "vite build --config web/vite.config.js",
    "game:test": "node --test tests/**/*.test.js",
    "game:test:screens": "node app/scripts/run-game-screenshot-check.js",
    "game:test:screens:debug": "node app/scripts/run-game-screenshot-check.js --debug",
    "game:dev:battle-page": "node app/scripts/open-dev-battle-page.js",
    "test": "node --test"
  },
  "dependencies": {
    "@playwright/test": "^1.58.2",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "marked": "^15.0.6",
    "openai": "^4.104.0",
    "pg": "^8.20.0",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.7",
    "puppeteer": "^24.7.1",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "telegram": "^2.26.22",
    "vite": "^8.0.3",
    "vue": "^3.5.31"
  }
}
